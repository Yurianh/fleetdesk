---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.jsx'
import CTASection from '../components/CTASection.astro'
import Footer from '../components/Footer.astro'

const APP_URL = 'https://app.fleetdesk.fr'

const plans = [
  {
    name: 'Starter',
    monthlyPrice: '9',
    annualPrice: '7',
    period: '/mois',
    annualTotal: '86',
    desc: 'Pour les artisans et indépendants qui veulent une flotte enfin organisée.',
    badge: null,
    trialNote: null,
    features: [
      { text: 'Jusqu\'à 5 véhicules et 3 conducteurs', highlight: false },
      { text: 'Fiches conducteurs avec coordonnées complètes', highlight: false },
      { text: 'Suivi kilométrique et enregistrements maintenance', highlight: false },
      { text: '6 documents réglementaires suivis par conducteur', highlight: false },
      { text: 'Support par email', highlight: false },
    ],
    cta: 'Commencer gratuitement',
    ctaHref: `${APP_URL}/login?plan=starter`,
    ctaStyle: 'border',
    highlighted: false,
  },
  {
    name: 'Pro',
    monthlyPrice: '29',
    annualPrice: '23',
    period: '/mois',
    annualTotal: '278',
    desc: 'Pour les équipes en croissance qui ne peuvent pas se permettre un incident de conformité.',
    badge: 'Le plus populaire',
    trialNote: '14 jours gratuits · Sans carte bancaire',
    features: [
      { text: 'Jusqu\'à 25 véhicules · conducteurs illimités', highlight: false },
      { text: 'Zéro contrôle technique raté — alertes 30j avant', highlight: true },
      { text: 'Alertes documents expirés avant les contrôles', highlight: true },
      { text: 'Prévisions de maintenance basées sur le kilométrage', highlight: false },
      { text: 'Tableau de bord analytique complet', highlight: false },
      { text: 'Suivi des lavages', highlight: false },
      { text: 'Support prioritaire', highlight: false },
    ],
    cta: 'Démarrer l\'essai gratuit',
    ctaHref: `${APP_URL}/login?plan=pro`,
    ctaStyle: 'primary',
    highlighted: true,
  },
  {
    name: 'Enterprise',
    monthlyPrice: '79',
    annualPrice: '63',
    period: '/mois',
    annualTotal: '758',
    desc: 'Pour les flottes multi-gestionnaires avec des exigences de traçabilité et d\'audit.',
    badge: null,
    trialNote: null,
    features: [
      { text: 'Véhicules et conducteurs illimités', highlight: false },
      { text: 'Jusqu\'à 10 gestionnaires avec rôles Admin / Membre', highlight: false },
      { text: 'Journal d\'activité complet — prêt pour les audits', highlight: true },
      { text: 'Onboarding personnalisé et SLA garanti', highlight: false },
      { text: 'Intégrations personnalisées', highlight: false },
      { text: 'Facturation sur mesure', highlight: false },
    ],
    cta: 'Contacter l\'équipe',
    ctaHref: '/contact',
    ctaStyle: 'border',
    highlighted: false,
  },
]

const faq = [
  {
    q: 'L\'essai Pro est-il vraiment sans carte bancaire ?',
    a: 'Oui. 14 jours d\'accès complet au plan Pro, sans rien saisir. Vous choisissez de continuer — ou pas. Aucun prélèvement automatique sans votre accord.'
  },
  {
    q: 'Puis-je changer de formule à tout moment ?',
    a: 'Oui. Passage à une formule supérieure ou inférieure depuis vos paramètres, à tout moment. Les modifications prennent effet au prochain cycle de facturation.'
  },
  {
    q: 'Que se passe-t-il si j\'atteins ma limite de véhicules ?',
    a: 'Vous êtes averti avant d\'atteindre la limite. Nous ne coupons jamais l\'accès sans avertissement — vous aurez toujours le temps de passer à une formule supérieure.'
  },
  {
    q: 'La facturation annuelle est-elle disponible ?',
    a: 'Oui, avec une remise de 20 %. Activez-la depuis vos paramètres ou contactez-nous pour la configurer. Vous payez en une fois pour l\'année et économisez 2 mois.'
  },
]
---
<Layout
  title="Tarifs"
  description="9 €/mois pour démarrer, 14 jours d'essai gratuit sur Pro. Sans engagement, sans carte bancaire. FleetDesk s'adapte à votre flotte."
>
  <Navbar client:load currentPath="/pricing" />

  <!-- Header -->
  <section class="bg-white border-b border-zinc-100 py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm font-semibold text-[#2563EB] tracking-wide mb-3">Tarifs</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-zinc-900 tracking-tight mb-5">
        Le prix juste pour votre flotte
      </h1>
      <p class="text-lg text-zinc-500 max-w-xl mx-auto">
        Démarrez en quelques minutes. Évoluez sans friction. Résiliez à tout moment.
      </p>
    </div>
  </section>

  <!-- Pricing cards -->
  <section id="plans" class="py-16 bg-zinc-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">

      <!-- Billing toggle -->
      <div class="flex items-center justify-center mb-12">
        <div class="inline-flex bg-white border border-zinc-200 rounded-full p-1 shadow-sm">
          <button
            id="btn-monthly"
            class="px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200 bg-zinc-900 text-white shadow"
          >
            Mensuel
          </button>
          <button
            id="btn-annual"
            class="px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200 text-zinc-500 hover:text-zinc-700 flex items-center gap-2"
          >
            Annuel
            <span class="text-[11px] font-bold text-emerald-600 bg-emerald-100 px-1.5 py-0.5 rounded-full">-20%</span>
          </button>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
        {plans.map(p => (
          <div class={`relative flex flex-col rounded-2xl p-7 ${p.highlighted ? 'border-2 border-[#2563EB] bg-white shadow-xl shadow-[#2563EB]/10 scale-[1.02]' : 'bg-white border border-zinc-200'}`}>

            {/* Badge */}
            {p.badge && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 whitespace-nowrap">
                <span class="bg-[#2563EB] text-white text-xs font-semibold px-3 py-1 rounded-full">{p.badge}</span>
              </div>
            )}

            {/* Plan name + price */}
            <div class="mb-5">
              <p class={`text-xs font-semibold uppercase tracking-widest mb-2 ${p.highlighted ? 'text-[#2563EB]' : 'text-zinc-400'}`}>{p.name}</p>
              <div class="flex items-end gap-1 mb-1">
                <span
                  class="price-amount text-4xl font-bold tracking-tight text-zinc-900 font-mono"
                  data-monthly={p.monthlyPrice}
                  data-annual={p.annualPrice}
                >
                  {p.monthlyPrice}
                </span>
                <span class="text-xl font-bold text-zinc-900 mb-0.5">€</span>
                <span class="text-sm mb-1.5 text-zinc-400">{p.period}</span>
              </div>
              {/* Annual subtotal line */}
              <p
                class="annual-total text-xs text-zinc-400 hidden"
                data-total={p.annualTotal}
              >
                soit {p.annualTotal} € / an
              </p>
              {p.trialNote && (
                <p class="text-xs font-semibold text-emerald-600 mt-1">{p.trialNote}</p>
              )}
            </div>

            {/* Description */}
            <p class="text-sm text-zinc-500 leading-relaxed mb-6 pb-6 border-b border-zinc-100">{p.desc}</p>

            {/* Features */}
            <ul class="space-y-3 mb-8 flex-1">
              {p.features.map(f => (
                <li class="flex items-start gap-2.5">
                  <svg class={`w-4 h-4 mt-0.5 flex-shrink-0 ${f.highlight ? 'text-emerald-500' : 'text-[#2563EB]'}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span class={`text-sm ${f.highlight ? 'text-zinc-800 font-medium' : 'text-zinc-600'}`}>{f.text}</span>
                </li>
              ))}
            </ul>

            {/* CTA */}
            <a
              href={p.ctaHref}
              class={`block w-full text-center text-sm font-semibold px-5 py-3 rounded-xl transition-colors ${
                p.ctaStyle === 'primary'
                  ? 'bg-[#2563EB] text-white hover:bg-[#1D4ED8]'
                  : 'border border-zinc-200 text-zinc-700 hover:bg-zinc-50'
              }`}
            >
              {p.cta}
            </a>
          </div>
        ))}
      </div>

      <!-- Trust bar -->
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 mt-10 text-xs text-zinc-400">
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Sans engagement
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Résiliation en 1 clic
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Données hébergées en France
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          Paiement sécurisé par Stripe
        </span>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold text-zinc-900 tracking-tight mb-10 text-center">Questions fréquentes</h2>
      <div class="space-y-0 divide-y divide-zinc-100">
        {faq.map(item => (
          <div class="py-6">
            <p class="font-semibold text-zinc-900 mb-2">{item.q}</p>
            <p class="text-sm text-zinc-500 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
  <Footer />
</Layout>

<script>
  const btnMonthly = document.getElementById('btn-monthly')
  const btnAnnual  = document.getElementById('btn-annual')
  const amounts    = document.querySelectorAll('.price-amount')
  const totals     = document.querySelectorAll('.annual-total')

  function setMonthly() {
    btnMonthly.classList.add('bg-zinc-900', 'text-white', 'shadow')
    btnMonthly.classList.remove('text-zinc-500')
    btnAnnual.classList.remove('bg-zinc-900', 'text-white', 'shadow')
    btnAnnual.classList.add('text-zinc-500')
    amounts.forEach(el => {
      el.textContent = el.dataset.monthly
    })
    totals.forEach(el => el.classList.add('hidden'))
  }

  function setAnnual() {
    btnAnnual.classList.add('bg-zinc-900', 'text-white', 'shadow')
    btnAnnual.classList.remove('text-zinc-500')
    btnMonthly.classList.remove('bg-zinc-900', 'text-white', 'shadow')
    btnMonthly.classList.add('text-zinc-500')
    amounts.forEach(el => {
      el.textContent = el.dataset.annual
    })
    totals.forEach(el => el.classList.remove('hidden'))
  }

  btnMonthly.addEventListener('click', setMonthly)
  btnAnnual.addEventListener('click', setAnnual)
</script>
