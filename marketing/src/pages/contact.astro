---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.jsx'
import ContactForm from '../components/ContactForm.jsx'
import Footer from '../components/Footer.astro'
---
<Layout
  title="Contact"
  description="Une question sur FleetDesk ? Vous voulez une démo ou de l'aide pour choisir une formule ? Contactez-nous."
>
  <Navbar client:load currentPath="/contact" />

  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-16">

        <!-- Left: info -->
        <div>
          <p class="text-sm font-semibold text-[#2563EB] tracking-wide mb-3">Contact</p>
          <h1 class="text-4xl font-bold text-zinc-900 tracking-tight mb-5">Contactez-nous</h1>
          <p class="text-lg text-zinc-500 mb-10">
            Une question sur FleetDesk ? Vous voulez une démo ou de l'aide pour choisir une formule ? Nous sommes là pour vous.
          </p>

          <div class="space-y-6">
            {[
              { title: 'Ventes et démos',    desc: 'Vous souhaitez voir FleetDesk en action ? Nous vous guidons.' },
              { title: 'Demandes générales', desc: 'Questions sur le produit, la facturation ou votre compte.' },
              { title: 'Temps de réponse',   desc: 'Nous répondons généralement dans un délai d\'un jour ouvrable.' },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-[#2563EB]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-zinc-900 mb-1">{item.title}</p>
                  <p class="text-sm text-zinc-500">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: form -->
        <div class="bg-white border border-zinc-200 rounded-2xl p-8">
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
