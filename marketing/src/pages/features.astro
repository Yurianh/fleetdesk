---
import Layout from '../layouts/Layout.astro'
import Navbar from '../components/Navbar.jsx'
import CTASection from '../components/CTASection.astro'
import Footer from '../components/Footer.astro'

const categories = [
  {
    title: 'Flotte & Conducteurs',
    features: [
      {
        title: 'Registre des véhicules',
        desc: 'Gardez une fiche complète pour chaque véhicule — marque, modèle, plaque, statut et historique complet en un seul endroit.',
        details: ['Statut en temps réel : actif, en maintenance, hors service', 'Historique complet des événements par véhicule', 'Recherche et filtres par marque, modèle ou plaque'],
        icon: '<path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>',
        bg: 'bg-blue-50', color: 'text-[#2563EB]', accentBg: 'bg-[#2563EB]',
      },
      {
        title: 'Profils conducteurs',
        desc: 'Fiche complète par conducteur — coordonnées, date de naissance, adresse domicile, ID unique. Tout ce qu\'il faut pour gérer votre équipe.',
        details: ['Téléphone, email, date de naissance et adresse domicile', 'ID conducteur unique avec validation anti-doublon', 'Historique des affectations par conducteur'],
        icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
        bg: 'bg-violet-50', color: 'text-violet-600', accentBg: 'bg-violet-600',
      },
      {
        title: 'Documents réglementaires',
        desc: 'Suivez les 6 documents obligatoires par conducteur — aptitude à la conduite, casier judiciaire, formations SST/PSC1, TPMR, visite médicale et éco-conduite.',
        details: ['Barre de progression et statut global par conducteur', 'Alertes segmentées : expirés, à renouveler bientôt, manquants', 'Calcul automatique des dates d\'expiration selon la réglementation'],
        icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>',
        bg: 'bg-rose-50', color: 'text-rose-600', accentBg: 'bg-rose-600',
      },
      {
        title: 'Affectations',
        desc: 'Affectez facilement des véhicules aux conducteurs, suivez les affectations en cours et passées, gérez les transitions sans confusion.',
        details: ['Vue instantanée : quel véhicule avec quel conducteur', 'Historique daté de toutes les affectations', 'Désaffectation en un clic'],
        icon: '<path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/>',
        bg: 'bg-emerald-50', color: 'text-emerald-600', accentBg: 'bg-emerald-600',
      },
      {
        title: 'Suivi kilométrique',
        desc: "Enregistrez les relevés d'odomètre régulièrement pour des dossiers kilométriques précis — essentiels pour les déclencheurs de maintenance.",
        details: ['Saisie rapide du kilométrage par véhicule', 'Historique chronologique des relevés', 'Calcul automatique des intervalles de maintenance'],
        icon: '<line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><circle cx="12" cy="12" r="4"/>',
        bg: 'bg-amber-50', color: 'text-amber-600', accentBg: 'bg-amber-600',
      },
    ],
  },
  {
    title: 'Opérations',
    features: [
      {
        title: 'Historique maintenance',
        desc: 'Consignez chaque service, réparation et remplacement de pièces. Définissez des plannings récurrents pour ne jamais manquer une maintenance.',
        details: ['Plannings récurrents par intervalle ou kilométrage', 'Coûts associés à chaque intervention', 'Alertes avant dépassement des échéances'],
        icon: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
        bg: 'bg-orange-50', color: 'text-orange-600', accentBg: 'bg-orange-600',
      },
      {
        title: 'Contrôles techniques',
        desc: "Suivez les dates de contrôle, les résultats et les prochaines échéances. Restez en conformité et évitez les oublis coûteux.",
        details: ['Résultats enregistrés : réussi, avis, refus', 'Rappels automatiques avant expiration', 'Vue consolidée de tous les véhicules à renouveler'],
        icon: '<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>',
        bg: 'bg-emerald-50', color: 'text-emerald-600', accentBg: 'bg-emerald-600',
      },
      {
        title: 'Suivi des lavages',
        desc: "Enregistrez les coûts et la fréquence de nettoyage par véhicule. Un détail qui compte pour les flottes soucieuses de leur image.",
        details: ['Date, type et coût de chaque lavage', 'Suivi de la fréquence par véhicule', 'Rapport des dépenses de nettoyage sur la période'],
        icon: '<path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/>',
        bg: 'bg-sky-50', color: 'text-sky-600', accentBg: 'bg-sky-600',
      },
    ],
  },
  {
    title: 'Analyses & Alertes',
    features: [
      {
        title: 'Tableau de bord analytique',
        desc: "Graphiques et résumés visuels des coûts, tendances kilométriques et activité de maintenance — sans tableur nécessaire.",
        details: ['KPIs en temps réel : véhicules actifs, coûts, alertes', 'Évolution kilométrique sur les 30 derniers jours', 'Répartition des dépenses par catégorie'],
        icon: '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
        bg: 'bg-blue-50', color: 'text-[#2563EB]', accentBg: 'bg-[#2563EB]',
      },
      {
        title: 'Prévision de maintenance',
        desc: "Anticipez les prochaines maintenances en fonction des intervalles kilométriques pour planifier à l'avance et réduire les temps d'arrêt.",
        details: ['Liste priorisée des véhicules à traiter en premier', 'Projection basée sur la cadence kilométrique réelle', "Vue calendaire des interventions à planifier"],
        icon: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/>',
        bg: 'bg-violet-50', color: 'text-violet-600', accentBg: 'bg-violet-600',
      },
      {
        title: 'Alertes & conformité',
        desc: "Tableau de bord d'alertes séparé entre véhicules et conducteurs — identifiez en un coup d'œil ce qui nécessite une action immédiate.",
        details: ['Deux sections distinctes : alertes véhicules et alertes conducteurs', 'Code couleur : action immédiate (rouge) ou à surveiller (orange)', 'Alertes documents expirés et contrôles techniques dépassés'],
        icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
        bg: 'bg-amber-50', color: 'text-amber-600', accentBg: 'bg-amber-600',
      },
    ],
  },
]
---
<Layout
  title="Fonctionnalités"
  description="De l'immatriculation des véhicules au suivi de conformité, FleetDesk couvre tout le cycle de gestion de flotte — sans la complexité."
>
  <Navbar client:load currentPath="/features" />

  <!-- Header -->
  <section class="bg-white border-b border-zinc-100 py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm font-semibold text-[#2563EB] tracking-wide mb-3">Fonctionnalités</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-zinc-900 tracking-tight mb-5">
        Tout ce qu'il faut pour votre flotte
      </h1>
      <p class="text-lg text-zinc-500 max-w-2xl mx-auto">
        De l'immatriculation des véhicules au suivi de conformité, FleetDesk couvre tout le cycle de gestion de flotte — sans la complexité.
      </p>
    </div>
  </section>

  <!-- Feature categories -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 space-y-20">
      {categories.map(cat => (
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-[0.1em] text-[#2563EB] mb-8">{cat.title}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {cat.features.map(f => (
              <div class="group relative bg-white border border-zinc-100 rounded-xl p-6 hover:-translate-y-1 hover:shadow-xl hover:border-zinc-200 transition-all duration-150 cursor-default overflow-hidden">
                <!-- accent line top -->
                <div class={`absolute inset-x-0 top-0 h-[2px] scale-x-0 group-hover:scale-x-100 transition-transform duration-200 origin-left rounded-t-xl ${f.accentBg}`} />

                <!-- icon -->
                <div class={`w-10 h-10 rounded-xl flex items-center justify-center mb-4 transition-transform duration-150 group-hover:scale-110 ${f.bg}`}>
                  <svg class={`w-5 h-5 ${f.color}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
                </div>

                <!-- title + desc -->
                <h3 class="text-sm font-semibold text-zinc-900 mb-2">{f.title}</h3>
                <p class="text-sm text-zinc-500 leading-relaxed">{f.desc}</p>

                <!-- expanded details on hover -->
                <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-all duration-200">
                  <div class="overflow-hidden">
                    <div class="pt-4 mt-4 border-t border-zinc-100">
                      <ul class="space-y-2">
                        {f.details.map(d => (
                          <li class="flex items-start gap-2 text-xs text-zinc-500">
                            <span class={`mt-0.5 shrink-0 w-1.5 h-1.5 rounded-full ${f.accentBg}`} />
                            {d}
                          </li>
                        ))}
                      </ul>
                      <a href="https://app.fleetdesk.fr/login" class={`inline-flex items-center gap-1 mt-4 text-xs font-semibold ${f.color} hover:underline`}>
                        Essayer gratuitement
                        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <CTASection />
  <Footer />
</Layout>
